threshold: medium
fileignoreconfig:
  - filename: pnpm-lock.yaml
    allowed_patterns:
      - ^sha512-[A-Za-z0-9+/]+={0,2}$
  - filename: .github/workflows/*
    allowed_patterns:
      - "[a-f0-9]{40}" # Allow pinned action commit SHAs
      - \$\{\{[^}]+\}\} # Allow GitHub Actions expression syntax (secrets.*, github.*, etc.)
